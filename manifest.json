{
  "manifest_version": 3,
  "name": "Element Vault",
  "version": "0.2.0",
  "description": "Remove page elements, inspect their attributes and CSS, and manage them from a Chrome side panel.",
  "permissions": [
    "storage",
    "sidePanel",
    "tabs",
    "declarativeNetRequest",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open Element Vault"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "adblock_rules",
        "enabled": true,
        "path": "rules/adblock-rules.json"
      }
    ]
  }
}
